{
  "ROS2.distro": "jazzy",
  "cmake.configureOnOpen": false,
  "cmake.configureArgs": [
    "-DPython3_EXECUTABLE=${env:ROS2_PY}\\python.exe",
    "-DCMAKE_C_COMPILER=${env:VSINSTALLDIR}VC\\Tools\\Llvm\\bin\\clang.exe",
    "-DCMAKE_CXX_COMPILER=${env:VSINSTALLDIR}VC\\Tools\\Llvm\\bin\\clang++.exe"
  ],
  "C_Cpp.intelliSenseEngine": "disabled",
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}",
    "--background-index",
    "--header-insertion=never"
  ],
  "python.analysis.typeCheckingMode": "basic",
  "cursorpyright.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "cursorpyright.analysis.autoImportCompletions": true,
  "python.analysis.indexing": true,
  "python.analysis.packageIndexDepths": [
    [
      "",
      20,
      true
    ]
  ],
  "debugpy.debugJustMyCode": true,
  "python.testing.pytestArgs": [
    "-s"
  ],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "python.defaultInterpreterPath": "${env:ROS2_PY}\\python.exe",
  "python.analysis.extraPaths": [
    "${env:ROS2_PY}\\Lib\\site-packages"
  ],
  "python.autoComplete.extraPaths": [
    "${env:ROS2_PY}\\Lib\\site-packages",
    "${env:ROS2_ROOT}\\Lib\\site-packages",
    "${workspaceFolder}\\build\\my_package",
    "${workspaceFolder}\\install\\my_package\\Lib\\site-packages",
  ],
  "files.exclude": {
    ".cache": true,
    ".history": true,
    ".idea": true,
    ".pytest_cache": true,
    "**/__pycache__": true
  },
  "python.languageServer": "None",
  "python.pyrefly.displayTypeErrors": "force-off",
  "cursorpyright.disableLanguageServices": true,
  "python.pyrefly.disableLanguageServices": false,
  // Using the light mode
  "indentRainbow.indicatorStyle": "light",
  // we use a simple 1 pixel wide line
  "indentRainbow.lightIndicatorStyleLineWidth": 1,
  // the same colors as above but more visible
  "indentRainbow.colors": [
    "rgba(255,255,64,0.3)",
    "rgba(127,255,127,0.3)",
    "rgba(255,127,255,0.3)",
    "rgba(79,236,236,0.3)"
  ],
  "cursorpyright.analysis.extraPaths": [
    "${env:ROS2_PY}\\Lib\\site-packages",
    "${env:ROS2_ROOT}\\Lib\\site-packages"
  ],
}